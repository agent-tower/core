{
  "name": "@agent-tower/server",
  "version": "0.3.20",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "agent-tower": "./dist/cli.js",
    "agent-tower-mcp": "./dist/mcp/index.js"
  },
  "scripts": {
    "postinstall": "prisma generate && node scripts/postinstall.js",
    "dev": "node scripts/dev.mjs",
    "build": "tsc && cp src/executors/default-profiles.json dist/executors/ && cp src/executors/default-providers.json dist/executors/",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@agent-tower/shared": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@prisma/client": "^5.9.1",
    "@shitiandmw/node-pty": "1.1.0-shitiandmw.1",
    "cloudflared": "^0.7.1",
    "fast-json-patch": "^3.1.1",
    "fastify": "^4.26.0",
    "simple-git": "^3.22.0",
    "smol-toml": "^1.6.0",
    "socket.io": "^4.8.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "prisma": "^5.9.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
