generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("AGENT_TOWER_DATABASE_URL")
}

// 项目
model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  repoPath    String
  repoRemoteUrl String?
  mainBranch  String   @default("main")
  copyFiles     String?  // 逗号分隔的 glob/路径列表，worktree 创建后自动复制
  setupScript   String?  // 多行命令文本，worktree 创建后自动执行
  quickCommands String?  // JSON: [{ name, command }]，终端快捷命令
  archivedAt  DateTime?
  repoDeletedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@index([archivedAt])
  @@index([repoDeletedAt])
}

// 任务
// TaskStatus: TODO, IN_PROGRESS, IN_REVIEW, DONE, CANCELLED
model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  status      String      @default("TODO")
  priority    Int         @default(0)
  position    Int         @default(0)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaces  Workspace[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
  @@index([status])
}

// 工作空间 (对应一个 git worktree)
// WorkspaceStatus: ACTIVE, MERGED, ABANDONED, HIBERNATED
model Workspace {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  branchName    String
  baseBranch    String?
  worktreePath  String
  status        String    @default("ACTIVE")
  commitMessage String?   // AI 生成的 commit message（合并时使用）
  hibernatedAt  DateTime? // 自动休眠时间
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskId])
}

// 会话 (一次 AI 代理执行)
// AgentType: CLAUDE_CODE, GEMINI_CLI, CURSOR_AGENT
// SessionStatus: PENDING, RUNNING, COMPLETED, FAILED, CANCELLED
// SessionPurpose: CHAT, COMMIT_MSG
model Session {
  id           String             @id @default(uuid())
  workspaceId  String
  workspace    Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agentType    String
  variant      String             @default("DEFAULT")
  providerId   String?
  prompt       String
  status       String             @default("PENDING")
  purpose      String             @default("CHAT")  // CHAT: 正常会话, COMMIT_MSG: 生成提交消息
  logSnapshot  String?            // 序列化的 NormalizedConversation JSON，session 结束时持久化
  tokenUsage   String?            // JSON: { totalTokens, modelContextWindow? }
  processes    ExecutionProcess[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([workspaceId])
}

// 执行进程
model ExecutionProcess {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pid       Int?
  exitCode  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

// 执行日志
model ExecutionLog {
  id        String   @id @default(uuid())
  processId String
  content   String
  timestamp DateTime @default(now())

  @@index([processId])
}

// 附件
model Attachment {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  hash         String
  createdAt    DateTime @default(now())

  @@index([hash])
}

// 应用设置 (单例，只有一行)
model AppSettings {
  id     String @id @default("singleton")
  locale String?
  commitMessageProviderId String?
  commitMessagePrompt     String?
}

// 通知配置 (单例，只有一行)
// thirdPartyChannel: none, feishu
model NotificationSettings {
  id                    String  @id @default("singleton")
  osNotificationEnabled Boolean @default(true)
  thirdPartyChannel     String  @default("none")
  feishuWebhookUrl      String?

  // 第三方通知跳转地址
  thirdPartyBaseUrl String?

  // 通知模板
  taskInReviewTitleTemplate String  @default("Agent Tower")
  taskInReviewBodyTemplate  String  @default("✅ \"{taskTitle}\" 已完成，等待审查")
}
