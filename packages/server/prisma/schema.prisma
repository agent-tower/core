generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("AGENT_TOWER_DATABASE_URL")
}

// 项目
model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  repoPath    String
  repoRemoteUrl String?
  mainBranch  String   @default("main")
  copyFiles     String?  // 逗号分隔的 glob/路径列表，worktree 创建后自动复制
  setupScript   String?  // 多行命令文本，worktree 创建后自动执行
  quickCommands String?  // JSON: [{ name, command }]，终端快捷命令
  archivedAt  DateTime?
  repoDeletedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]

  @@index([archivedAt])
  @@index([repoDeletedAt])
}

// 任务
// TaskStatus: TODO, IN_PROGRESS, IN_REVIEW, DONE, CANCELLED
model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  status      String      @default("TODO")
  priority    Int         @default(0)
  position    Int         @default(0)
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaces  Workspace[]
  teamRun     TeamRun?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
}

// 后台任务删除资源清理
// TaskCleanupJobStatus: PENDING, RUNNING, COMPLETED, FAILED
model TaskCleanupJob {
  id           String    @id @default(uuid())
  taskId       String
  projectId    String
  payload      String    // JSON cleanup snapshot: project/workspaces/sessions
  status       String    @default("PENDING")
  attempts     Int       @default(0)
  lastError    String?
  nextRetryAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([taskId])
  @@index([status, nextRetryAt])
  @@index([projectId])
}

model MemberPreset {
  id              String   @id @default(uuid())
  name            String
  aliases         String // JSON string: string[]
  providerId      String
  rolePrompt      String
  capabilities    String // JSON TeamMemberCapabilities
  workspacePolicy String
  triggerPolicy   String
  sessionPolicy   String   @default("new_per_request")
  queueManagementPolicy String @default("own_only")
  avatar          String? // JSON or string ref
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TeamTemplate {
  id        String               @id @default(uuid())
  name      String
  members   TeamTemplateMember[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

model TeamTemplateMember {
  id             String       @id @default(uuid())
  teamTemplateId String
  teamTemplate   TeamTemplate @relation(fields: [teamTemplateId], references: [id], onDelete: Cascade)
  memberPresetId String
  position       Int          @default(0)

  @@index([teamTemplateId])
  @@index([memberPresetId])
}

model TeamRun {
  id              String            @id @default(uuid())
  taskId          String            @unique
  task            Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mainWorkspaceId String?
  mainWorkspace   Workspace?        @relation("TeamRunMainWorkspace", fields: [mainWorkspaceId], references: [id], onDelete: SetNull)
  mode            String
  reviewReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  members         TeamMember[]
  messages        RoomMessage[]
  workRequests    WorkRequest[]
  invocations     AgentInvocation[]
  verdicts        WorkspaceVerdict[]

  @@index([mainWorkspaceId])
}

model TeamMember {
  id              String   @id @default(uuid())
  teamRunId       String
  teamRun         TeamRun  @relation(fields: [teamRunId], references: [id], onDelete: Cascade)
  presetId        String?
  name            String
  aliases         String // JSON string: string[]
  providerId      String
  rolePrompt      String
  capabilities    String // JSON TeamMemberCapabilities
  workspacePolicy String
  triggerPolicy   String
  sessionPolicy   String   @default("new_per_request")
  queueManagementPolicy String @default("own_only")
  membershipStatus String  @default("ACTIVE")
  avatar          String?
  status          String   @default("IDLE")
  ownedWorkspaces Workspace[] @relation("WorkspaceOwner")
  roomMessageParticipants RoomMessageParticipant[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([teamRunId])
  @@index([teamRunId, membershipStatus])
}

model RoomMessage {
  id                 String   @id @default(uuid())
  teamRunId          String
  teamRun            TeamRun  @relation(fields: [teamRunId], references: [id], onDelete: Cascade)
  senderType         String
  senderId           String?
  senderInvocationId String?
  kind               String
  visibility         String   @default("PUBLIC")
  content            String
  mentions           String // JSON StructuredMention[]
  workRequestIds     String? // JSON string[]
  artifactRefs       String? // JSON string[]
  attachmentIds      String? // JSON string[]
  participants       RoomMessageParticipant[]
  createdAt          DateTime @default(now())

  @@index([teamRunId])
  @@index([teamRunId, visibility])
  @@index([senderInvocationId])
}

model RoomMessageParticipant {
  id            String      @id @default(uuid())
  teamRunId     String
  roomMessageId String
  roomMessage   RoomMessage @relation(fields: [roomMessageId], references: [id], onDelete: Cascade)
  memberId      String
  member        TeamMember  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role          String
  createdAt     DateTime    @default(now())

  @@unique([roomMessageId, memberId])
  @@index([teamRunId, memberId])
  @@index([roomMessageId])
  @@index([memberId])
}

model WorkRequest {
  id                String   @id @default(uuid())
  teamRunId         String
  teamRun           TeamRun  @relation(fields: [teamRunId], references: [id], onDelete: Cascade)
  requesterMemberId String?
  requesterType     String
  targetMemberId    String
  targetKind        String?
  targetPurpose     String?
  targetSourceWorkspaceId String?
  targetSourceMemberId String?
  targetHeadSha     String?
  targetBranchName  String?
  targetPlanItemId  String?
  triggerMessageId  String
  instruction       String
  ifBusy            String   @default("queue")
  cancelQueued      Boolean  @default(false)
  status            String   @default("QUEUED")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([teamRunId])
  @@index([targetMemberId])
  @@index([targetSourceWorkspaceId])
  @@index([targetHeadSha])
  @@index([status])
}

model AgentInvocation {
  id                      String    @id @default(uuid())
  teamRunId               String
  teamRun                 TeamRun   @relation(fields: [teamRunId], references: [id], onDelete: Cascade)
  workRequestId           String
  memberId                String
  workspaceId             String?
  sessionId               String?
  targetKind              String?
  targetPurpose           String?
  targetSourceWorkspaceId String?
  targetSourceMemberId    String?
  targetHeadSha           String?
  targetBranchName        String?
  targetPlanItemId        String?
  targetSyncStatus        String?
  targetSyncError         String?
  targetExecutionBranch   String?
  targetPort              Int?
  targetVitePort          Int?
  targetE2EPort           Int?
  status                  String    @default("QUEUED")
  roomReplyReminderCount  Int       @default(0)
  nextRoomReplyReminderAt DateTime?
  lastHeartbeatAt         DateTime? // 最近一次真实进展（session:patch / room message）时间，心跳 watchdog 比对用
  firstNudgeAt            DateTime? // 首次心跳唤醒时间，作为绝对兜底起点（收到 room message 或终态时清空）
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([teamRunId])
  @@index([memberId])
  @@index([sessionId])
  @@index([targetSourceWorkspaceId])
  @@index([targetHeadSha])
  @@index([targetSyncStatus])
  @@index([status])
}

// 工作空间
// WorkspaceStatus: ACTIVE, MERGED, ABANDONED, HIBERNATED
// WorkspaceKind: WORKTREE, MAIN_DIRECTORY
model Workspace {
  id            String    @id @default(uuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parentWorkspaceId String?
  parentWorkspace   Workspace?  @relation("WorkspaceChildren", fields: [parentWorkspaceId], references: [id], onDelete: SetNull)
  childWorkspaces   Workspace[] @relation("WorkspaceChildren")
  ownerMemberId     String?
  ownerMember       TeamMember? @relation("WorkspaceOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  mainForTeamRuns   TeamRun[]   @relation("TeamRunMainWorkspace")
  branchName    String
  baseBranch    String?
  worktreePath  String
  workspaceKind String    @default("WORKTREE")
  workingDir    String    @default("")
  status        String    @default("ACTIVE")
  commitMessage String?   // AI 生成的 commit message（合并时使用）
  previewTarget String?   // Preview 代理目标（仅允许 loopback 地址）
  hibernatedAt  DateTime? // 自动休眠时间
  sessions      Session[]
  verdicts      WorkspaceVerdict[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([taskId])
  @@index([parentWorkspaceId])
  @@index([ownerMemberId])
  @@index([taskId, parentWorkspaceId])
  @@index([workspaceKind])
  @@index([workingDir])
  @@unique([parentWorkspaceId, ownerMemberId])
}

// 工作区审查/测试记录
// WorkspaceVerdictKind: REVIEW, TEST
// REVIEW verdict: APPROVED, CHANGES_REQUESTED
// TEST verdict: PASSED, FAILED
model WorkspaceVerdict {
  id               String    @id @default(uuid())
  workspaceId      String
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  teamRunId        String
  teamRun          TeamRun   @relation(fields: [teamRunId], references: [id], onDelete: Cascade)
  kind             String
  verdict          String
  reviewedSha      String
  reviewerMemberId String?
  reason           String?
  sequence         Int       @default(0)
  createdAt        DateTime  @default(now())

  @@index([workspaceId, kind, createdAt])
  @@index([workspaceId, kind, sequence])
  @@index([teamRunId])
  @@index([reviewerMemberId])
}

// 独立对话：不绑定 Project/Task/Workspace，仅复用 Session 执行链路
model Conversation {
  id            String    @id @default(uuid())
  title         String
  directoryName String    @unique
  workingDir    String
  session       Session?
  deletedAt     DateTime?
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([deletedAt])
  @@index([lastActiveAt])
}

// 会话 (一次 AI 代理执行)
// AgentType: CLAUDE_CODE, GEMINI_CLI, CURSOR_AGENT
// SessionStatus: PENDING, RUNNING, COMPLETED, FAILED, CANCELLED
// SessionPurpose: CHAT, COMMIT_MSG
model Session {
  id           String             @id @default(uuid())
  workspaceId  String?
  workspace    Workspace?         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversationId String?          @unique
  conversation Conversation?      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  context      String             @default("WORKSPACE") // WORKSPACE: 项目工作区, CONVERSATION: 独立对话
  agentType    String
  variant      String             @default("DEFAULT")
  providerId   String?
  prompt       String
  status       String             @default("PENDING")
  purpose      String             @default("CHAT")  // CHAT: 正常会话, COMMIT_MSG: 生成提交消息
  logSnapshot  String?            // 序列化的 NormalizedConversation JSON，session 结束时持久化
  tokenUsage   String?            // JSON: { totalTokens, modelContextWindow? }
  processes    ExecutionProcess[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([workspaceId])
  @@index([context])
}

// 执行进程
model ExecutionProcess {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  pid       Int?
  exitCode  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
}

// 执行日志
model ExecutionLog {
  id        String   @id @default(uuid())
  processId String
  content   String
  timestamp DateTime @default(now())

  @@index([processId])
}

// 附件
model Attachment {
  id           String   @id @default(uuid())
  originalName String
  mimeType     String
  sizeBytes    Int
  storagePath  String
  hash         String
  createdAt    DateTime @default(now())

  @@index([hash])
}

// 应用设置 (单例，只有一行)
model AppSettings {
  id     String @id @default("singleton")
  locale String?
  commitMessageProviderId String?
  commitMessagePrompt     String?
}

// 访问密码配置 (单例，只有一行)
model AccessAuthSettings {
  id                String    @id @default("singleton")
  enabled           Boolean   @default(false)
  passwordHash      String?
  sessionSecret     String
  passwordUpdatedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// 通知配置 (单例，只有一行)
// thirdPartyChannel: none, feishu
model NotificationSettings {
  id                    String  @id @default("singleton")
  osNotificationEnabled Boolean @default(true)
  thirdPartyChannel     String  @default("none")
  feishuWebhookUrl      String?

  // 第三方通知跳转地址
  thirdPartyBaseUrl String?

  // 通知模板
  taskInReviewTitleTemplate String  @default("Agent Tower")
  taskInReviewBodyTemplate  String  @default("✅ \"{taskTitle}\" 已完成，等待审查")
}
