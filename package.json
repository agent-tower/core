{
  "name": "agent-tower",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent 任务管理面板",
  "scripts": {
    "setup": "pnpm install && pnpm db:push",
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "db:generate": "pnpm --filter @agent-tower/server run db:generate",
    "db:push": "pnpm --filter @agent-tower/server run db:push"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "cloudflared",
      "esbuild",
      "node-pty",
      "prisma"
    ]
  }
}
