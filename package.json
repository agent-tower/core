{
  "name": "agent-tower",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent 任务管理面板",
  "license": "Apache-2.0",
  "scripts": {
    "setup": "pnpm install && pnpm --filter @agent-tower/shared build",
    "dev": "pnpm -r --parallel --filter '!@agent-tower/docs-site' run dev",
    "dev:all": "pnpm -r --parallel run dev",
    "desktop:spike": "pnpm --filter @agent-tower/desktop spike",
    "desktop:package:dir": "pnpm --filter @agent-tower/desktop package:dir",
    "desktop:package:acceptance": "pnpm --filter @agent-tower/desktop package:acceptance",
    "desktop:package:smoke": "pnpm --filter @agent-tower/desktop package:smoke",
    "build": "pnpm -r run build",
    "docs:dev": "pnpm --filter @agent-tower/docs-site dev",
    "docs:build": "pnpm --filter @agent-tower/docs-site build",
    "docs:serve": "pnpm --filter @agent-tower/docs-site serve",
    "build:publish": "node scripts/build-publish.mjs",
    "lint": "pnpm -r run lint",
    "clean": "pnpm -r run clean",
    "db:generate": "pnpm --filter @agent-tower/server run db:generate",
    "db:push": "pnpm --filter @agent-tower/server run db:push"
  },
  "devDependencies": {
    "fast-check": "^4.5.3",
    "happy-dom": "^16.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
